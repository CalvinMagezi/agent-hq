# ═══════════════════════════════════════════════════════════════════════
# Agent-HQ — Environment Variables (Rust Edition)
# ═══════════════════════════════════════════════════════════════════════
#
# Copy to .env.local and fill in your values:
#   cp .env.example .env.local
#
# Primary config is in ~/.hq/config.yaml (created by `hq setup`).
# These env vars supplement the config for features that need them.
# ═══════════════════════════════════════════════════════════════════════

# ─── LLM Configuration ─────────────────────────────────────────────
OPENROUTER_API_KEY=
DEFAULT_MODEL=moonshotai/kimi-k2.5

# ─── Relay: Discord ───────────────────────────────────────────────
# DISCORD_BOT_TOKEN=
# DISCORD_USER_ID=

# ─── Relay: Telegram ──────────────────────────────────────────────
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_USER_ID=

# ─── Relay: WhatsApp ──────────────────────────────────────────────
# WHATSAPP_OWNER_JID=your-phone@s.whatsapp.net

# ─── Voice Transcription ─────────────────────────────────────────
# GROQ_API_KEY=

# ─── Email (IMAP/SMTP) ───────────────────────────────────────────
# IMAP_HOST=mail.example.com
# IMAP_PORT=993
# IMAP_USER=you@example.com
# IMAP_PASS=
# SMTP_HOST=mail.example.com
# SMTP_PORT=465
# SMTP_USER=you@example.com
# SMTP_PASS=
# MAIL_FROM_NAME=Your Name
# MAIL_ACCOUNT_LABEL=you@example.com

# ─── Optional Features ───────────────────────────────────────────
# MORNING_BRIEF_ENABLED=false
# VAULT_WORKERS_ENABLED=true
# NVIDIA_NIM_API_KEY=
# BRAVE_SEARCH_API_KEY=
# OLLAMA_BASE_URL=http://localhost:11434
