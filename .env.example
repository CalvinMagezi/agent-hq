# ═══════════════════════════════════════════════════════════════════════
# Agent-HQ — Root Environment Variables
# ═══════════════════════════════════════════════════════════════════════
#
# This file is the single source of truth for shared environment variables.
# All apps and scripts load from here automatically via @repo/env-loader.
#
# You can also create per-app .env.local files (e.g. apps/agent/.env.local)
# to override specific vars for that app. Per-app vars take priority.
#
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local
# ═══════════════════════════════════════════════════════════════════════

# ─── LLM Configuration ─────────────────────────────────────────────
OPENROUTER_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
DEFAULT_MODEL=gemini-2.5-flash

# ─── HQ CLI Harness (scripts/hq-run.ts) ──────────────────────────
# NVIDIA NIM: free Kimi K2.5 access (40 RPM). Get key at build.nvidia.com
NVIDIA_NIM_API_KEY=
# Override default model (default: moonshotai/kimi-k2.5)
# HQ_MODEL=moonshotai/kimi-k2.5
# Override fallback model (default: google/gemini-3.1-flash-lite-preview)
# HQ_FALLBACK_MODEL=google/gemini-3.1-flash-lite-preview

# ─── Vault ──────────────────────────────────────────────────────────
# Leave blank to use the default .vault/ in the repo root
# VAULT_PATH=

# ─── Security ──────────────────────────────────────────────────────
# Shared API key for relay server + adapters (leave blank for open local access)
# AGENTHQ_API_KEY=

# ─── Discord ────────────────────────────────────────────────────────
# DISCORD_BOT_TOKEN=
# DISCORD_USER_ID=
# DISCORD_BOT_TOKEN_OPENCODE=
# DISCORD_BOT_TOKEN_GEMINI=

# ─── Telegram ───────────────────────────────────────────────────────
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_USER_ID=

# ─── WhatsApp ───────────────────────────────────────────────────────
# WHATSAPP_OWNER_JID=

# ─── Voice / Transcription ──────────────────────────────────────────
# GROQ_API_KEY=

# ─── Google Workspace ───────────────────────────────────────────────
# GOOGLE_WORKSPACE_CLI_CREDENTIALS_FILE=

# ─── Push Notifications (Control Center PWA) ────────────────────────
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=

# ─── Optional / Advanced ───────────────────────────────────────────
# BRAVE_API_KEY=
# EMBEDDING_MODEL=openai/text-embedding-3-small
# MORNING_BRIEF_ENABLED=true
# VAULT_WORKERS_ENABLED=false
# OLLAMA_BASE_URL=http://localhost:11434
