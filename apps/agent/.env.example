# LLM Configuration
OPENROUTER_API_KEY=
GEMINI_API_KEY=
DEFAULT_MODEL=gemini-2.5-flash

# Provider routing:
# - "gemini-*" or "google/gemini-*" models use GEMINI_API_KEY directly (if set)
# - All other models use OPENROUTER_API_KEY
# - Gemini models fall back to OpenRouter if GEMINI_API_KEY is not set

# Agent Working Directory (optional)
# TARGET_DIR=

# API Key for relay/webhook endpoints (optional)
AGENTHQ_API_KEY=
