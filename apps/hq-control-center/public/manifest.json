{
  "name": "HQ Control Center",
  "short_name": "HQ",
  "description": "Agent HQ monitoring dashboard",
  "theme_color": "#0a0a0f",
  "background_color": "#0a0a0f",
  "display": "standalone",
  "display_override": ["window-controls-overlay", "standalone"],
  "orientation": "any",
  "start_url": "/",
  "scope": "/",
  "lang": "en-US",
  "categories": ["utilities", "productivity"],
  "icons": [
    { "src": "/icons/icon-192.png", "sizes": "192x192", "type": "image/png", "purpose": "any" },
    { "src": "/icons/icon-512.png", "sizes": "512x512", "type": "image/png", "purpose": "any maskable" }
  ],
  "shortcuts": [
    { "name": "Vault", "url": "/vault", "description": "Browse vault files" },
    { "name": "Recent Jobs", "url": "/", "description": "View running and pending jobs" },
    { "name": "Teams", "url": "/teams", "description": "Agent team status" },
    { "name": "Plans", "url": "/plans", "description": "View project plans" }
  ],
  "share_target": {
    "action": "/share",
    "method": "GET",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  }
}
